# GoodFinds WMS — environment variables
# Copy to .env and fill with your own values. DO NOT commit real keys.

# Supabase project URL (e.g. https://<project-ref>.supabase.co)
PUBLIC_SUPABASE_URL=your-supabase-url

# Supabase publishable / anon key (safe for client use; respects RLS)
PUBLIC_SUPABASE_ANON_KEY=your-anon-key
